rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() { return signedIn() && userDoc().role == 'admin' && userDoc().enabled == true; }
    function isStaffPlus() {
      return signedIn() && userDoc().enabled == true &&
      (userDoc().role in ['admin', 'manager', 'assistant_manager', 'lead', 'staff']);
    }

    match /evidence/{allPaths=**} {
      allow read: if isStaffPlus();
      allow write: if isStaffPlus();
      allow delete: if isAdmin();
    }

    match /backups/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
