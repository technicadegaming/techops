rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return signedIn() && userDoc().enabled == true && userDoc().role == role; }
    function isAdmin() { return hasRole('admin'); }
    function isManagerPlus() { return isAdmin() || hasRole('manager'); }
    function isAssistantPlus() { return isManagerPlus() || hasRole('assistant_manager'); }
    function isLeadPlus() { return isAssistantPlus() || hasRole('lead'); }
    function isStaffPlus() { return isLeadPlus() || hasRole('staff'); }

    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == uid && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /{collection}/{docId} {
      allow read: if isStaffPlus();
      allow create, update: if isLeadPlus();
      allow delete: if isManagerPlus();
    }

    match /appSettings/{docId} {
      allow read: if isStaffPlus();
      allow write: if isAdmin();
    }

    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isStaffPlus();
      allow update, delete: if false;
    }

    match /backups/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
